# Base
* text=auto

# Texto/código del proyecto
*.rb    text eol=lf
*.pbs   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Archivos típicos de Windows
*.bat    text eol=crlf
